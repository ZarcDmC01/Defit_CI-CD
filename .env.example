# Copy to .env and adjust as needed

# Use "mock" to skip HuggingFace downloads during development
INFERENCE_ENGINE=mock
# INFERENCE_ENGINE=huggingface

# Model IDs (only used when INFERENCE_ENGINE=huggingface)
SUMMARIZATION_MODEL=sshleifer/distilbart-cnn-12-6
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
QA_MODEL=deepset/minilm-uncased-squad2

MAX_FILE_SIZE_MB=5
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860

# MongoDB — for local dev; Docker Compose overrides this with the service hostname
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=defit
